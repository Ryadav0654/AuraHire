{
  "name": "aurahire.ai",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "web:docker": "cd apps/web && pnpm run build && pnpm run start"
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "turbo": "^2.5.4"
  },
  "packageManager": "pnpm@8.15.6",
  "workspaces": [
    "apps/web",
    "apps/api",
    "packages/@repo/db",
    "packages/@repo/ui"
  ],
  "engines": {
    "node": ">=18"
  }
}